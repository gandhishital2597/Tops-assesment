Objective
Build a console-based Student Productivity Tracker that logs daily study hours and
generates a weekly report.
Your application must:
1. Menu-driven program
2. Log daily study hours
3. Generate weekly report
4. Store data using files

ANswer : 
import os

FILE_NAME = "study_data.txt"

# Function to log study hours
def log_hours():
    day = input("Enter day (e.g., Monday): ")
    hours = input("Enter study hours: ")

    with open(FILE_NAME, "a") as file:
        file.write(day + "," + hours + "\n")

    print("✅ Study hours logged successfully!\n")


# Function to display weekly report
def weekly_report():
    if not os.path.exists(FILE_NAME):
        print("❌ No data found!\n")
        return

    total_hours = 0
    days_count = 0

    print("\n📊 Weekly Report")
    print("----------------------")

    with open(FILE_NAME, "r") as file:
        for line in file:
            day, hours = line.strip().split(",")
            hours = float(hours)

            print(f"{day}: {hours} hours")
            total_hours += hours
            days_count += 1

    if days_count > 0:
        avg = total_hours / days_count
    else:
        avg = 0

    print("----------------------")
    print(f"Total Hours: {total_hours}")
    print(f"Average per day: {avg:.2f}\n")


# Main menu
def main():
    while True:
        print("===== Student Productivity Tracker =====")
        print("1. Log Study Hours")
        print("2. View Weekly Report")
        print("3. Exit")

        choice = input("Enter your choice: ")

        if choice == "1":
            log_hours()
        elif choice == "2":
            weekly_report()
        elif choice == "3":
            print("👋 Exiting program...")
            break
        else:
            print("❌ Invalid choice! Try again.\n")


# Run program
main()

